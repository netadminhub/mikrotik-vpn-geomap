<!DOCTYPE html>
<html>
<head>
    <title>Download World Map</title>
</head>
<body>
    <script>
        fetch('https://raw.githubusercontent.com/apache/echarts-examples/gh-pages/public/data/asset/geo/world.json')
            .then(res => res.json())
            .then(data => {
                console.log(JSON.stringify(data));
            });
    </script>
</body>
</html>
